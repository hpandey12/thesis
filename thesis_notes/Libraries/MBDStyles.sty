\newif\if@english

\DeclareOption{german}{
\@germantrue}

\DeclareOption{english}{
\@englishtrue}

\ProcessOptions

\if@german
	\RequirePackage[ngerman]{babel}
	\RequirePackage[ngerman]{translator}
\else
	\RequirePackage[english]{babel}
	\RequirePackage[english]{translator}
\fi

