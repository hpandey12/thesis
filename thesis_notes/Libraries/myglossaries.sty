\DeclareOption{german}{
\@germantrue}

\DeclareOption{english}{
\@englishtrue}

\ProcessOptions


% =============================================================================================================
% Allgemeine Aufrufe und Formatierung
% -------------------------------------------------------------------------------------------------------------
% Package einbinden
\usepackage[toc, nonumberlist, style=longheader]{glossaries}[=v4.49]

% Zus�tzliche Glossare 'index' und 'abkz'
\if@german
	\newglossary[slg]{index}{syi}{syg}{Indizes}
	\newglossary[abg]{abkz}{abi}{abo}{Abk�rzungen}
\else
	\newglossary[slg]{index}{syi}{syg}{Indices}
	\newglossary[abg]{abkz}{abi}{abo}{Acronyms}
\fi


% Glossare anlegen
\makeglossaries

% Allgemeine Formatierung der Glossare
\renewcommand*{\glsgroupskip}{}		% Entfernen des Abstandes zwischen Gruppen
\renewcommand*{\glspostdescription}{}	% Der Punkt am Ende jeder Beschreibung wird weggelassen 
\renewcommand{\glossaryname}{Glossar}	% �berschrift f�r das Glossar 'main'

% Style f�r Sub-Entries
\renewcommand*{\glossarysubentryfield}[6]{\glossaryentryfield{#2}{#3}{#4}{#5}{#6}}

% Hier m�ssen \entryname und \description mit leeren Argumenten definiert werden da ansonsten in den Headern die default Bezeichnungen "Notation" und "Description" zusammen mit den in Abkz und Glossar vorgegebenen Bezeichnungen ausgegeben werden
\renewcommand{\entryname}{}
\renewcommand{\descriptionname}{}
