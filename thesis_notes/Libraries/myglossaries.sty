% -------------------------------------------------------------------------------------------------------------   
% Abk�rzungen - ohne Untergruppen
% -------------------------------------------------------------------------------------------------------------
\newglossarystyle{Abkzg}
{
	\if@german
 		\renewcommand*{\glossaryheader}{\bfseries \entryname{Abk�rzung} & \bfseries \descriptionname{Bedeutung}\\ & \\\endhead}
	\else
		\renewcommand*{\glossaryheader}{}
	\fi
  \renewenvironment{theglossary}
    {
    \begin{longtable}{p{\glstargetwidth} @{\hspace{\glshspace}} p{\glsdescwidth}}
    }
    {\end{longtable}}
  % Format f�r Gruppen�berschrift festlegen
  \renewcommand*{\glossaryentryfield}[5]{\textbf{\glstarget{##1}{##2}} & ##3 \\}
  % Format f�r Eintr�ge
  %\renewcommand*{\glossarysubentryfield}[6]{##3 & ##4 \\}
}
