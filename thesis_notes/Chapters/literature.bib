@article{sugrueAssessmentSimplifiedSet2017,
  title = {Assessment of a Simplified Set of Momentum Closure Relations for Low Volume Fraction Regimes in {{STAR-CCM}}+ and {{OpenFOAM}}},
  author = {Sugrue, Rosemary and Magolan, Ben and Lubchenko, Nazar and Baglietto, Emilio},
