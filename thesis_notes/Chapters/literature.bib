@article{gopalakrishnaExperimentalStudyFlash1987,
  title = {An Experimental Study of Flash Evaporation from Liquid Pools},
  author = {Gopalakrishna, S. and Purushothaman, V. M. and Lior, N.},
  year = {1987},
  journal = {Desalination},
  shortjournal = {Desalination},
