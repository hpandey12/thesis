package macro;

import star.common.*;
import star.base.neo.*;

public class AmrMacro extends StarMacro {

    @Override
    public void execute() {
        // Get the active simulation
        Simulation sim = getActiveSimulation();

        // Retrieve the physical time stopping criterion
        StoppingCriterionManager stoppingManager = sim.getStoppingCriterionManager();
        PhysicalTimeStoppingCriterion timeStopCriterion = 
            (PhysicalTimeStoppingCriterion) stoppingManager.getCriterion("Physical Time");
        // Get the maximum physical time from the stopping criterion
        double maxTime = timeStopCriterion.getMaximumTime();

        // Get the mesh operation named "amr"
        MeshOperationManager meshOpManager = sim.get(MeshOperationManager.class);
        AutoMeshOperation amrOperation = 
            (AutoMeshOperation) meshOpManager.getObject("amr");

        // 1) Mesh the file initially
        amrOperation.execute();

        // 2) Initialize (or re-initialize) the solution
        sim.initializeSolution();

        // 3) Continue iterating until the simulation reaches the maximum time
        while (sim.getSolution().getPhysicalTime() < maxTime) {
            // Advance the solution by one iteration
            sim.getSimulationIterator().step(1);

            // Execute the "amr" mesh operation again
            amrOperation.execute();
        }
    }
}